class Solution:
    def minimumHammingDistance(self, source: List[int], target: List[int], allowedSwaps: List[List[int]]) -> int:
        n = len(source)
        if n == 0:
            return 0
        
        # Union-Find
        parent = list(range(n))
        rank = [0] * n
        
        def find(x):
            if parent[x] != x:
                parent[x] = find(parent[x])
            return parent[x]
        
        def union(x, y):
            px, py = find(x), find(y)
            if px != py:
                if rank[px] < rank[py]:
                    parent[px] = py
                elif rank[px] > rank[py]:
                    parent[py] = px
                else:
                    parent[py] = px
                    rank[px] += 1
        
        for a, b in allowedSwaps:
            union(a, b)
        
        # Group source and target values by component root
        from collections import defaultdict, Counter
        src_groups = defaultdict(list)
        tgt_groups = defaultdict(list)
        for i in range(n):
            root = find(i)
            src_groups[root].append(source[i])
            tgt_groups[root].append(target[i])
        
        # Calculate maximum matches per component
        total_matches = 0
        for root in src_groups:
            src_cnt = Counter(src_groups[root])
            tgt_cnt = Counter(tgt_groups[root])
            matches = sum(min(src_cnt.get(v, 0), tgt_cnt.get(v, 0)) for v in src_cnt)
            total_matches += matches
        
        return n - total_matches

"""
Approach & Reasoning:
The allowedSwaps define an undirected graph on the indices (0 to n-1). Because any number of swaps are permitted along the given edges, within each connected component of this graph the values in source can be arbitrarily rearranged among the positions belonging to that component.

To minimize the Hamming distance we must therefore maximize the number of positions i where the final value at i equals target[i]. This can be done independently for each component:

- Collect the multiset of source values and the multiset of target values for the indices in the component.
- For each distinct value v the maximum number of matches possible for v is min(source_count[v], target_count[v]).
- Summing these minima over all v gives the maximum number of correct positions achievable inside the component.

The overall minimum Hamming distance is then n minus the sum of these maximum matches across all components.

We use Union-Find (with path compression and union-by-rank) to identify the connected components in O(n + |allowedSwaps|) time. Then we group the relevant source/target values by their component root and use Counter to compute the required frequency minima.

Time Complexity: O(n α(n) + n) where α is the inverse Ackermann function (practically constant).
Space Complexity: O(n)
"""
