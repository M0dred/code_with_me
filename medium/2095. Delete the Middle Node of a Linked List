# Definition for singly-linked list.
# class ListNode:
#     def __init__(self, val=0, next=None):
#         self.val = val
#         self.next = next

class Solution:
    def deleteMiddle(self, head: Optional[ListNode]) -> Optional[ListNode]:
        # Create a dummy node pointing to head to handle edge cases uniformly
        dummy = ListNode(0, head)
        slow, fast = dummy, head
        
        # Move fast by 2 steps and slow by 1 step until fast reaches the end
        while fast and fast.next:
            fast = fast.next.next
            slow = slow.next
        
        # slow is now at the node before the middle node
        slow.next = slow.next.next
        
        return dummy.next

'''
Approach:
1. Create a dummy node pointing to the head to simplify deletion of the head itself.
2. Use two pointers: slow starts at dummy, fast starts at head.
3. Advance fast by 2 steps and slow by 1 step per iteration. When fast reaches the end 
   of the list, slow will be positioned at the node immediately before the middle node.
4. Delete the middle node by skipping it (slow.next = slow.next.next).
5. Return dummy.next as the new head.

Time Complexity: O(N), where N is the number of nodes in the linked list.
Space Complexity: O(1).
'''
