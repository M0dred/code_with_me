class Solution:
    def rotate(self, matrix: List[List[int]]) -> None:
        """
        Do not return anything, modify matrix in-place instead.
        """
        n = len(matrix)
        # Transpose
        for i in range(n):
            for j in range(i + 1, n):
                matrix[i][j], matrix[j][i] = matrix[j][i], matrix[i][j]
        # Reverse each row
        for row in matrix:
            row.reverse()

"""
Approach & Reasoning:
To rotate an n x n matrix 90 degrees clockwise in-place:
1. First transpose the matrix: swap elements across the main diagonal (matrix[i][j] ↔ matrix[j][i] for i < j).
2. Then reverse each row individually.

This transforms the original position (i, j) → (j, n-1-i), which is exactly the mapping for a 90-degree clockwise rotation.

The operations are done directly on the input matrix without allocating extra space, satisfying the in-place requirement.

Time Complexity: O(n²)
Space Complexity: O(1)
"""
