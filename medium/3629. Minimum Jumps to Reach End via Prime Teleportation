from collections import defaultdict, deque

class Solution:
    MAX = 1000010
    spf = list(range(MAX))
    for i in range(2, int(MAX**0.5) + 1):
        if spf[i] == i:
            for j in range(i * i, MAX, i):
                if spf[j] == j:
                    spf[j] = i

    def minJumps(self, nums: List[int]) -> int:
        n = len(nums)
        if n == 1:
            return 0

        def is_prime(x):
            if x < 2:
                return False
            return Solution.spf[x] == x

        def get_prime_factors(x):
            factors = set()
            while x > 1:
                p = Solution.spf[x]
                factors.add(p)
                while x % p == 0:
                    x //= p
            return factors

        primes_in_array = set()
        for num in nums:
            if is_prime(num):
                primes_in_array.add(num)

        prime_to_targets = defaultdict(list)
        for j in range(n):
            if nums[j] > 1:
                factors = get_prime_factors(nums[j])
                for p in factors:
                    if p in primes_in_array:
                        prime_to_targets[p].append(j)

        dist = [-1] * n
        dist[0] = 0
        q = deque([0])
        activated = set()

        while q:
            i = q.popleft()
            if i == n - 1:
                return dist[i]
            # adjacent moves
            for d in [-1, 1]:
                ni = i + d
                if 0 <= ni < n and dist[ni] == -1:
                    dist[ni] = dist[i] + 1
                    q.append(ni)
            # teleportation (activate prime only once)
            p = nums[i]
            if is_prime(p) and p not in activated:
                activated.add(p)
                for j in prime_to_targets[p]:
                    if j != i and dist[j] == -1:
                        dist[j] = dist[i] + 1
                        q.append(j)
        return -1

"""
Approach & Reasoning:
Precompute the smallest-prime-factor (SPF) sieve once for the whole class (up to 10^6+10). This allows O(1) primality testing and fast factorization of any nums[j].

Collect all primes that appear in nums, then for each position j factorize nums[j] and record j in the target list of every qualifying prime factor p. The total size of all target lists is O(n log MAX_NUM) (very small in practice).

Run a standard BFS from index 0:
- Support the two adjacent moves (i±1) at every step.
- Teleportation edges for a prime p are added exactly once — the first time any position with nums[i] == p is dequeued (lazy activation). All targets of p are then enqueued with cost +1 if not yet visited.

Because each index is enqueued at most once and the total number of teleport edges processed across all primes is linear in n, the whole algorithm runs in O(n + n log MAX_NUM) time.

The activation guarantees that teleport targets receive the minimal possible distance (the first time a source of that prime is reached).

Time Complexity: O(n log MAX_NUM)
Space Complexity: O(n + MAX_NUM)
"""
