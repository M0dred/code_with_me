class Solution:
    def numberOfSpecialChars(self, word: str) -> int:
        n = len(word)
        last_lower = [-1] * 26
        first_upper = [n] * 26
        for i, ch in enumerate(word):
            if ch.islower():
                idx = ord(ch) - ord('a')
                last_lower[idx] = i
            else:
                idx = ord(ch) - ord('A')
                if first_upper[idx] == n:
                    first_upper[idx] = i
        count = 0
        for i in range(26):
            if last_lower[i] != -1 and first_upper[i] != n and last_lower[i] < first_upper[i]:
                count += 1
        return count

"""
Approach & Reasoning:
A letter c is special only if both its lowercase and uppercase versions appear at least once, and the last occurrence of lowercase c is strictly before the first occurrence of uppercase C.

Track two arrays in a single left-to-right pass:
- last_lower[26]: the rightmost index where the lowercase letter appears.
- first_upper[26]: the leftmost index where the uppercase letter appears (initialized to n, updated only on the first sighting).

After processing the whole string, iterate over the 26 letters and count how many satisfy:
- last_lower[i] != -1 (lowercase exists)
- first_upper[i] != n (uppercase exists)
- last_lower[i] < first_upper[i] (all lowercase before first uppercase)

The condition precisely matches the definition of "special". Separate index calculations for lowercase (ord(c) - ord('a')) and uppercase (ord(c) - ord('A')) prevent index errors.

Time Complexity: O(n)
Space Complexity: O(1)
"""
