from typing import List

class Solution:
    def numberOfStableArrays(self, zero: int, one: int, limit: int) -> int:
        MOD = 10**9 + 7

        # dp0[i][j]: number of valid arrays using i zeros and j ones, ending with 0
        # dp1[i][j]: number of valid arrays using i zeros and j ones, ending with 1
        dp0 = [[0] * (one + 1) for _ in range(zero + 1)]
        dp1 = [[0] * (one + 1) for _ in range(zero + 1)]

        for i in range(1, min(zero, limit) + 1):
            dp0[i][0] = 1
        for j in range(1, min(one, limit) + 1):
            dp1[0][j] = 1

        for i in range(zero + 1):
            for j in range(one + 1):
                if i > 0 and j > 0:
                    # Append a 0 to any valid array ending with 1
                    dp0[i][j] = dp0[i - 1][j] + dp1[i - 1][j]
                    if i - limit - 1 >= 0:
                        # Remove cases where the ending run of 0s would exceed limit
                        dp0[i][j] -= dp1[i - limit - 1][j]
                    dp0[i][j] %= MOD

                    # Append a 1 to any valid array ending with 0
                    dp1[i][j] = dp0[i][j - 1] + dp1[i][j - 1]
                    if j - limit - 1 >= 0:
                        # Remove cases where the ending run of 1s would exceed limit
                        dp1[i][j] -= dp0[i][j - limit - 1]
                    dp1[i][j] %= MOD

        return (dp0[zero][one] + dp1[zero][one]) % MOD


"""
Approach & Reasoning:

A stable array is exactly a binary array with:
- exactly `zero` zeros,
- exactly `one` ones,
- no run of consecutive equal values longer than `limit`.

So this is a counting DP with a run-length constraint.

Define:
- dp0[i][j] = number of valid arrays using i zeros and j ones, ending with 0
- dp1[i][j] = number of valid arrays using i zeros and j ones, ending with 1

Transitions:

1) To form dp0[i][j]:
   We append a 0 to an array with (i-1) zeros and j ones.
   Before enforcing the run limit, that gives:
       dp0[i-1][j] + dp1[i-1][j]

   But some of those create a suffix of (limit+1) zeros, which is invalid.
   Those bad arrays are exactly the ones that, before appending those zeros,
   ended with 1 and used:
       i - limit - 1 zeros, j ones
   so subtract:
       dp1[i-limit-1][j]

   Therefore:
       dp0[i][j] = dp0[i-1][j] + dp1[i-1][j] - dp1[i-limit-1][j]

2) Similarly:
       dp1[i][j] = dp0[i][j-1] + dp1[i][j-1] - dp0[i][j-limit-1]

Base cases:
- If we use only zeros, the array is valid only if the number of zeros is at most limit,
  so dp0[i][0] = 1 for 1 <= i <= limit.
- If we use only ones, similarly dp1[0][j] = 1 for 1 <= j <= limit.

Finally, the answer is:
    dp0[zero][one] + dp1[zero][one]

Time Complexity: O(zero * one)
Space Complexity: O(zero * one)
"""
