from typing import List

class Solution:
    def pathExistenceQueries(self, n: int, nums: List[int], maxDiff: int, queries: List[List[int]]) -> List[bool]:
        # Compute connected components by scanning adjacent gaps
        comp = [0] * n
        comp_id = 0
        comp[0] = comp_id
        
        for i in range(1, n):
            if nums[i] - nums[i - 1] > maxDiff:
                comp_id += 1
            comp[i] = comp_id
        
        ans = []
        for u, v in queries:
            ans.append(comp[u] == comp[v])
        
        return ans

'''
Approach:
1. Since `nums` is sorted in non-decreasing order, the graph has a special structure: 
   an edge exists between nodes i and j (i < j) iff nums[j] - nums[i] <= maxDiff.
2. If nums[i] - nums[i-1] > maxDiff for some adjacent pair, then no node on the left 
   of this gap can connect to any node on the right, because any cross-gap difference 
   is at least as large as this adjacent gap. Thus, these gaps separate the graph 
   into contiguous connected components.
3. Scan through `nums` once to assign component IDs. Start a new component whenever 
   nums[i] - nums[i-1] > maxDiff.
4. For each query, two nodes are connected iff they share the same component ID.

Time Complexity: O(N + Q), where N is the length of nums and Q is the number of queries.
Space Complexity: O(N).
'''
