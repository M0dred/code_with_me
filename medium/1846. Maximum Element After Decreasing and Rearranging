from typing import List

class Solution:
    def maximumElementAfterDecrementingAndRearranging(self, arr: List[int]) -> int:
        arr.sort()
        arr[0] = 1
        
        for i in range(1, len(arr)):
            arr[i] = min(arr[i], arr[i - 1] + 1)
        
        return arr[-1]

'''
Approach:
1. Sort the array so we can greedily assign values from left to right.
2. Set the first element to 1, as required by the condition.
3. For each subsequent element at index i, the maximum value it can take is the minimum of its original value and the previous element's value plus 1. This ensures we only decrease elements while maintaining the adjacent difference constraint.
4. The last element after this greedy pass is the maximum possible value.

Time Complexity: O(N log N), where N is the length of arr.
Space Complexity: O(N).
'''
