from typing import List

class Solution:
    def minAbsDiff(self, grid: List[List[int]], k: int) -> List[List[int]]:
        m, n = len(grid), len(grid[0])
        ans = [[0] * (n - k + 1) for _ in range(m - k + 1)]

        for i in range(m - k + 1):
            for j in range(n - k + 1):
                vals = set()
                for r in range(i, i + k):
                    for c in range(j, j + k):
                        vals.add(grid[r][c])

                if len(vals) <= 1:
                    ans[i][j] = 0
                    continue

                arr = sorted(vals)
                best = float("inf")
                for t in range(1, len(arr)):
                    best = min(best, arr[t] - arr[t - 1])

                ans[i][j] = best

        return ans


"""
Approach & Reasoning:

For each k x k submatrix, we need the minimum absolute difference between any two distinct values.

Key observation:
If we sort the distinct values in the submatrix, the minimum absolute difference must occur
between two adjacent values in sorted order.

So for every submatrix:
1) Collect all values inside the k x k window into a set
   - using a set removes duplicates, because the problem asks about distinct values
2) If there is only one distinct value, the answer is 0
3) Otherwise sort the distinct values
4) Scan adjacent pairs and take the minimum difference

Constraints are small:
- m, n <= 30
So a direct brute-force over all windows is fully acceptable.

Time Complexity:
- There are (m-k+1)(n-k+1) submatrices
- Each one processes k^2 cells and sorts up to k^2 distinct values
- Overall this is fast enough for the given limits

Space Complexity: O(k^2) per submatrix for the set/sorted list
"""
