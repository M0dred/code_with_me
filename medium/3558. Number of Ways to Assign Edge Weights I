from typing import List
from collections import deque

class Solution:
    def assignEdgeWeights(self, edges: List[List[int]]) -> int:
        MOD = 10**9 + 7
        n = len(edges) + 1
        
        # Build adjacency list for the tree
        adj = [[] for _ in range(n + 1)]
        for u, v in edges:
            adj[u].append(v)
            adj[v].append(u)
        
        # BFS from root (node 1) to find the maximum depth
        max_depth = 0
        visited = [False] * (n + 1)
        queue = deque([(1, 0)])
        visited[1] = True
        
        while queue:
            node, depth = queue.popleft()
            max_depth = max(max_depth, depth)
            for neighbor in adj[node]:
                if not visited[neighbor]:
                    visited[neighbor] = True
                    queue.append((neighbor, depth + 1))
        
        # For a path with d edges, each edge can be 1 (odd) or 2 (even).
        # The total cost is odd iff an odd number of edges are assigned 1.
        # Number of valid assignments = C(d,1) + C(d,3) + ... = 2^(d-1).
        return pow(2, max_depth - 1, MOD)

'''
Approach:
1. Build an adjacency list from the given edges.
2. Perform BFS/DFS starting from the root node 1 to compute the depth of every node.
   The maximum depth found is the number of edges d in the path from node 1 to any 
   deepest node x.
3. For the d edges on the path from 1 to x, each edge can be assigned weight 1 (odd) 
   or 2 (even). The total cost is odd if and only if an odd number of edges are 
   assigned weight 1. The count of such assignments is the sum of binomial coefficients 
   C(d, k) for all odd k, which equals 2^(d-1).
4. Return 2^(d-1) modulo 10^9 + 7.

Time Complexity: O(N), where N is the number of nodes.
Space Complexity: O(N).
'''
