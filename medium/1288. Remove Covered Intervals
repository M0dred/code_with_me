from typing import List

class Solution:
    def removeCoveredIntervals(self, intervals: List[List[int]]) -> int:
        # Sort by left endpoint ascending; for ties, sort by right endpoint descending
        intervals.sort(key=lambda x: (x[0], -x[1]))
        
        count = 0
        max_right = -1
        
        for left, right in intervals:
            if right > max_right:
                count += 1
                max_right = right
        
        return count

'''
Approach:
1. Sort intervals by left endpoint in ascending order. For intervals with the same 
   left endpoint, sort by right endpoint in descending order so that the wider 
   interval comes first.
2. Iterate through the sorted intervals and maintain the maximum right endpoint 
   seen so far.
3. If the current interval's right endpoint is greater than the maximum right 
   endpoint seen, it is not covered by any previous interval; increment the count 
   and update the maximum right endpoint.
4. If the current interval's right endpoint is less than or equal to the maximum 
   right endpoint seen, it is covered by some previous interval and is skipped.
5. Return the count of remaining intervals.

Time Complexity: O(N log N), where N is the length of intervals.
Space Complexity: O(N).
'''
