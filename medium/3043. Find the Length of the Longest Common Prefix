class TrieNode:
    def __init__(self):
        self.children = {}

class Solution:
    def longestCommonPrefix(self, arr1: List[int], arr2: List[int]) -> int:
        root = TrieNode()
        # Insert all numbers from arr1 as strings into the Trie
        for num in arr1:
            s = str(num)
            node = root
            for ch in s:
                if ch not in node.children:
                    node.children[ch] = TrieNode()
                node = node.children[ch]
        
        # For each number in arr2, find the longest prefix match in the Trie
        max_len = 0
        for num in arr2:
            s = str(num)
            node = root
            length = 0
            for ch in s:
                if ch in node.children:
                    node = node.children[ch]
                    length += 1
                    max_len = max(max_len, length)
                else:
                    break
        return max_len

"""
Approach & Reasoning:
Build a Trie (prefix tree) containing every integer from arr1 represented as its decimal digit string. Each node corresponds to a prefix.

For every integer in arr2, also converted to a string, walk down the Trie following its digits as long as the child exists. The number of successful steps is the length of the longest prefix this number shares with any number in arr1. Track the global maximum length across all such queries.

Because each insertion and each query processes only the digits of the numbers (at most 9 per number) and the total size of the Trie is bounded by the total number of digits in arr1, the algorithm runs efficiently.

If no common prefix exists for any pair the answer stays 0, as required.

Time Complexity: O(total digits in arr1 + total digits in arr2) = O(n + m) where n = arr1.length, m = arr2.length
Space Complexity: O(total digits in arr1)
"""
