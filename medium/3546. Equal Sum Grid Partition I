from typing import List

class Solution:
    def canPartitionGrid(self, grid: List[List[int]]) -> bool:
        m, n = len(grid), len(grid[0])

        total = 0
        row_sum = [0] * m
        col_sum = [0] * n

        for i in range(m):
            for j in range(n):
                val = grid[i][j]
                total += val
                row_sum[i] += val
                col_sum[j] += val

        if total % 2 != 0:
            return False

        target = total // 2

        cur = 0
        for i in range(m - 1):  # cut between row i and i+1
            cur += row_sum[i]
            if cur == target:
                return True

        cur = 0
        for j in range(n - 1):  # cut between col j and j+1
            cur += col_sum[j]
            if cur == target:
                return True

        return False


"""
Approach & Reasoning:

A valid cut must split the grid into two non-empty parts with equal sum.
So the total sum of the grid must be even; otherwise it is impossible.

There are only two types of cuts:
1) Horizontal cut:
   split between row i and row i+1
2) Vertical cut:
   split between column j and column j+1

For a horizontal cut:
- the top part contains complete rows [0..i]
- the bottom part contains rows [i+1..m-1]
So we only need row sums and check whether some prefix of rows equals total / 2.

For a vertical cut:
- the left part contains complete columns [0..j]
- the right part contains columns [j+1..n-1]
So we only need column sums and check whether some prefix of columns equals total / 2.

Steps:
1) Compute total sum, row sums, and column sums.
2) If total is odd, return False.
3) Scan row prefix sums for a horizontal cut.
4) Scan column prefix sums for a vertical cut.
5) Return True if any valid cut is found.

Time Complexity: O(mn)
Space Complexity: O(m + n)
"""
