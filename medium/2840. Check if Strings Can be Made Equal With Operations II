class Solution:
    def checkStrings(self, s1: str, s2: str) -> bool:
        even1 = []
        odd1 = []
        even2 = []
        odd2 = []
        
        for i in range(len(s1)):
            if i % 2 == 0:
                even1.append(s1[i])
                even2.append(s2[i])
            else:
                odd1.append(s1[i])
                odd2.append(s2[i])
        
        # Sort them to compare multisets
        even1.sort()
        odd1.sort()
        even2.sort()
        odd2.sort()
        
        # Check if they match
        return even1 == even2 and odd1 == odd2

"""
Approach & Reasoning:
The allowed operation swaps characters whose indices differ by an even number.
For length 4, this means:
- index 0 can swap with index 2 (diff=2 even)
- index 1 can swap with index 3 (diff=2 even)
- No connection between even and odd indices (diff would be odd).

This splits the string into two independent groups:
- Even positions: {0, 2}
- Odd positions: {1, 3}

Within each group of size 2, we can freely rearrange the characters (by swapping or doing nothing).

Therefore, it is possible to make s1 equal to s2 if and only if:
- The multiset of characters at positions {0, 2} is the same in both strings
- The multiset of characters at positions {1, 3} is the same in both strings

We check this by sorting the pairs and comparing them.

Time Complexity: O(1)
Space Complexity: O(1)
"""
