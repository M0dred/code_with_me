from typing import List

class Solution:
    def maxProductPath(self, grid: List[List[int]]) -> int:
        MOD = 10**9 + 7
        m, n = len(grid), len(grid[0])

        max_dp = [[0] * n for _ in range(m)]
        min_dp = [[0] * n for _ in range(m)]

        max_dp[0][0] = min_dp[0][0] = grid[0][0]

        for i in range(1, m):
            val = grid[i][0]
            max_dp[i][0] = min_dp[i][0] = max_dp[i - 1][0] * val

        for j in range(1, n):
            val = grid[0][j]
            max_dp[0][j] = min_dp[0][j] = max_dp[0][j - 1] * val

        for i in range(1, m):
            for j in range(1, n):
                val = grid[i][j]

                candidates = (
                    max_dp[i - 1][j] * val,
                    min_dp[i - 1][j] * val,
                    max_dp[i][j - 1] * val,
                    min_dp[i][j - 1] * val,
                )

                max_dp[i][j] = max(candidates)
                min_dp[i][j] = min(candidates)

        ans = max_dp[m - 1][n - 1]
        return ans % MOD if ans >= 0 else -1


"""
Approach & Reasoning:

Because the grid can contain negative numbers, the maximum product at a cell is not enough by itself.
A negative value can turn a very small (most negative) product into a very large positive product.

So for each cell, we maintain:
- max_dp[i][j] = maximum product of any path ending at (i, j)
- min_dp[i][j] = minimum product of any path ending at (i, j)

Why both are needed:
- If grid[i][j] is positive:
    max stays from previous max, min stays from previous min
- If grid[i][j] is negative:
    previous min may become the new max
    previous max may become the new min

Transition:
From each cell, we can only come from:
- top: (i-1, j)
- left: (i, j-1)

So at cell (i, j), we consider:
- max_dp[i-1][j] * val
- min_dp[i-1][j] * val
- max_dp[i][j-1] * val
- min_dp[i][j-1] * val

Then:
- max_dp[i][j] = max(all candidates)
- min_dp[i][j] = min(all candidates)

Initialization:
- Start cell is grid[0][0]
- First row and first column each have only one possible path

At the end:
- If max_dp[m-1][n-1] is negative, return -1
- Otherwise return it modulo 10^9 + 7

Time Complexity: O(mn)
Space Complexity: O(mn)
"""
