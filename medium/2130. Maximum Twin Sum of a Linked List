# Definition for singly-linked list.
# class ListNode:
#     def __init__(self, val=0, next=None):
#         self.val = val
#         self.next = next

class Solution:
    def pairSum(self, head: Optional[ListNode]) -> int:
        # Find the middle of the linked list using slow/fast pointers
        slow, fast = head, head
        while fast and fast.next:
            slow = slow.next
            fast = fast.next.next
        
        # Reverse the second half of the linked list starting from slow
        prev = None
        curr = slow
        while curr:
            nxt = curr.next
            curr.next = prev
            prev = curr
            curr = nxt
        
        # Iterate through the first half and reversed second half simultaneously
        max_sum = 0
        first, second = head, prev
        while second:
            max_sum = max(max_sum, first.val + second.val)
            first = first.next
            second = second.next
        
        return max_sum

'''
Approach:
1. Find the middle of the linked list using the slow/fast pointer technique. 
   When fast reaches the end, slow points to the start of the second half.
2. Reverse the second half of the linked list in-place.
3. Iterate simultaneously through the first half (from head) and the reversed 
   second half, computing the twin sum for each pair.
4. Track and return the maximum twin sum encountered.

Time Complexity: O(N), where N is the number of nodes in the linked list.
Space Complexity: O(1).
'''
