class Solution:
    def countBinarySubstrings(self, s: str) -> int:
        prev = 0
        cur = 1
        ans = 0

        for i in range(1, len(s)):
            if s[i] == s[i - 1]:
                cur += 1
            else:
                ans += min(prev, cur)
                prev = cur
                cur = 1

        ans += min(prev, cur)
        return ans


"""
Approach & Reasoning:

A valid substring must look like:
    000...0111...1  or  111...1000...0
i.e., exactly two consecutive groups, and the two groups must have the same length.

So we compress the string into lengths of consecutive runs.
Example: "00110011" -> [2, 2, 2, 2]

For every adjacent pair of runs (prev_run, cur_run),
the number of valid substrings contributed is:
    min(prev_run, cur_run)
because we can take 1..min(prev,cur) characters from each side.

We do this in one pass without storing all runs:
- cur = length of current run
- prev = length of previous run
Whenever the character changes:
    ans += min(prev, cur)
    shift prev = cur, reset cur = 1
At the end, add the last pair contribution.

Time Complexity: O(n)
Space Complexity: O(1)
"""
