class Solution:
    def leftRightDifference(self, nums: List[int]) -> List[int]:
        n = len(nums)
        total = sum(nums)
        answer = [0] * n
        left = 0
        for i in range(n):
            right = total - left - nums[i]
            answer[i] = abs(left - right)
            left += nums[i]
        return answer

"""
Approach & Reasoning:
Compute the total sum of the array once. Then iterate from left to right while maintaining a running `left` sum (sum of elements before the current index).

For each index i:
- rightSum[i] = total - leftSum[i] - nums[i]
- answer[i] = |leftSum[i] - rightSum[i]|
- Add nums[i] to leftSum for the next iteration.

This computes both left and right sums in a single O(n) pass after the initial O(n) sum, using only O(1) extra space (excluding the output array).

Time Complexity: O(n)
Space Complexity: O(1) (excluding output array)
"""
