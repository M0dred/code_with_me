class Solution:
    def earliestFinishTime(self, landStartTime: List[int], landDuration: List[int], waterStartTime: List[int], waterDuration: List[int]) -> int:
        INF = 10**9
        ans = INF
        n = len(landStartTime)
        m = len(waterStartTime)
        for i in range(n):
            for j in range(m):
                # land first
                finish_land = landStartTime[i] + landDuration[i]
                start_water = max(finish_land, waterStartTime[j])
                finish1 = start_water + waterDuration[j]
                # water first
                finish_water = waterStartTime[j] + waterDuration[j]
                start_land = max(finish_water, landStartTime[i])
                finish2 = start_land + landDuration[i]
                ans = min(ans, finish1, finish2)
        return ans

"""
Approach & Reasoning:
For every possible pair (land ride i, water ride j) we compute the finish time in both possible orders:

* Land ride first:
  * Finish land ride at landStartTime[i] + landDuration[i].
  * Start water ride at max(finish time of land, waterStartTime[j]).
  * Total finish time = start of water + waterDuration[j].

* Water ride first:
  * Finish water ride at waterStartTime[j] + waterDuration[j].
  * Start land ride at max(finish time of water, landStartTime[i]).
  * Total finish time = start of land + landDuration[i].

We keep the minimum finish time over all pairs and both orders.

Because n, m ≤ 100 the double loop runs in O(n * m) = O(10^4) time, which is efficient.

Time Complexity: O(n * m)
Space Complexity: O(1)
"""
