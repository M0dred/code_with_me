class Solution:
    def minimumDistance(self, nums: List[int]) -> int:
        from collections import defaultdict
        pos = defaultdict(list)
        for i, num in enumerate(nums):
            pos[num].append(i)
        min_dist = float('inf')
        for p in pos.values():
            if len(p) >= 3:
                for i in range(len(p) - 2):
                    span = p[i + 2] - p[i]
                    min_dist = min(min_dist, 2 * span)
        return min_dist if min_dist != float('inf') else -1

"""
Approach & Reasoning:
Any good triplet of indices i < j < k (with nums[i] == nums[j] == nums[k]) has distance
abs(i-j) + abs(j-k) + abs(k-i) = 2 * (k - i). Thus the distance depends only on the
span between the outermost pair.

For each value, collect its sorted list of indices (built in increasing order).
If a value appears at least 3 times, consider every consecutive triple of indices
and compute the minimal (p[r+2] - p[r]) among them. Multiply that minimal span by 2
to get the best distance achievable for this value.

Track the global minimum across all values. If no value appears >= 3 times, return -1.

This exploits the fixed 2*(max-min) property and the fact that the smallest possible
span for any three occurrences is the minimum over all sliding windows of size 3 in
the sorted index list.

Time Complexity: O(n) (building the map + O(n) for scanning all windows)
Space Complexity: O(n)
"""
