from typing import List

class Solution:
    def readBinaryWatch(self, turnedOn: int) -> List[str]:
        res = []

        for h in range(12):
            for m in range(60):
                if (h.bit_count() + m.bit_count()) == turnedOn:
                    res.append(f"{h}:{m:02d}")

        return res


"""
Approach & Reasoning:

A valid time consists of:
- Hours: 0 to 11 (4 LEDs)
- Minutes: 0 to 59 (6 LEDs)

We simply try all possible valid times:
For each hour h in [0, 11]
For each minute m in [0, 59]
    Count the number of 1 bits in h and m.
    If h.bit_count() + m.bit_count() == turnedOn,
    then this time is valid.

Formatting rules:
- Hour: no leading zero
- Minute: always two digits (use format "{m:02d}")

Since total possibilities are small (12 × 60 = 720),
brute force is perfectly efficient.

Time Complexity: O(1) (at most 720 checks)
Space Complexity: O(1)
"""
