from collections import deque, defaultdict

class Solution:
    def minJumps(self, arr: List[int]) -> int:
        n = len(arr)
        if n <= 1:
            return 0
        val_to_indices = defaultdict(list)
        for i, v in enumerate(arr):
            val_to_indices[v].append(i)
        queue = deque([0])
        visited = [False] * n
        visited[0] = True
        steps = 0
        while queue:
            size = len(queue)
            for _ in range(size):
                i = queue.popleft()
                if i == n - 1:
                    return steps
                # adjacent jumps
                for d in [-1, 1]:
                    ni = i + d
                    if 0 <= ni < n and not visited[ni]:
                        visited[ni] = True
                        queue.append(ni)
                # same value jumps (process each value only once)
                for j in val_to_indices[arr[i]]:
                    if not visited[j]:
                        visited[j] = True
                        queue.append(j)
                val_to_indices[arr[i]].clear()
            steps += 1
        return -1

"""
Approach & Reasoning:
This is a shortest path problem on a graph where nodes are indices. Edges exist to adjacent indices (i±1) and to all indices with the same value.

Use BFS for minimum steps. To optimize the same-value jumps (which could be many), pre-group indices by value. When processing a position, enqueue all other indices with the same value only once per unique value (by clearing the list after use). This ensures each index is enqueued at most once.

Time Complexity: O(n)
Space Complexity: O(n)
"""
