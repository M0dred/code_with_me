import heapq
from typing import List

class Solution:
    def maxTotalValue(self, nums: List[int], k: int) -> int:
        n = len(nums)
        
        # Build sparse tables for range maximum and minimum queries
        LOG = n.bit_length()
        st_max = [[0] * n for _ in range(LOG)]
        st_min = [[0] * n for _ in range(LOG)]
        
        for i in range(n):
            st_max[0][i] = nums[i]
            st_min[0][i] = nums[i]
        
        for j in range(1, LOG):
            step = 1 << (j - 1)
            for i in range(n - (1 << j) + 1):
                st_max[j][i] = max(st_max[j-1][i], st_max[j-1][i + step])
                st_min[j][i] = min(st_min[j-1][i], st_min[j-1][i + step])
        
        # Precompute logarithms for query lengths
        log = [0] * (n + 1)
        for i in range(2, n + 1):
            log[i] = log[i >> 1] + 1
        
        def range_max(l: int, r: int) -> int:
            j = log[r - l + 1]
            return max(st_max[j][l], st_max[j][r - (1 << j) + 1])
        
        def range_min(l: int, r: int) -> int:
            j = log[r - l + 1]
            return min(st_min[j][l], st_min[j][r - (1 << j) + 1])
        
        def subarray_value(l: int, r: int) -> int:
            return range_max(l, r) - range_min(l, r)
        
        # Max-heap simulated with negative values
        # Each state represents the best remaining subarray starting at l, ending at r
        heap = []
        for l in range(n):
            val = subarray_value(l, n - 1)
            heapq.heappush(heap, (-val, l, n - 1))
        
        total = 0
        for _ in range(k):
            neg_val, l, r = heapq.heappop(heap)
            total += -neg_val
            if r > l:
                next_val = subarray_value(l, r - 1)
                heapq.heappush(heap, (-next_val, l, r - 1))
        
        return total

'''
Approach:
1. Preprocess the array with sparse tables to answer range max/min queries in O(1).
2. Observe that for a fixed left endpoint l, as the right endpoint r decreases, 
   the subarray value max(l,r) - min(l,r) is non-increasing.
3. Use a max-heap to track the current best subarray for each starting index l.
   Initialize by pushing all subarrays [l, n-1] for l in range(n).
4. Repeat k times:
   - Pop the subarray with the largest value from the heap.
   - Add its value to the total.
   - If its right endpoint is greater than its left endpoint, push the next 
     subarray for the same l with r decremented by 1 ([l, r-1]).
5. Return the accumulated total.

Time Complexity: O(N log N + K log N), where N is the length of nums.
Space Complexity: O(N log N).
'''
