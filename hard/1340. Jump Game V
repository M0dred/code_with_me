class Solution:
    def maxJumps(self, arr: List[int], d: int) -> int:
        n = len(arr)
        memo = [-1] * n
        
        def dp(i: int) -> int:
            if memo[i] != -1:
                return memo[i]
            res = 1
            # right jumps
            for j in range(i + 1, min(n, i + d + 1)):
                if arr[j] >= arr[i]:
                    break
                res = max(res, 1 + dp(j))
            # left jumps
            for j in range(i - 1, max(-1, i - d - 1), -1):
                if arr[j] >= arr[i]:
                    break
                res = max(res, 1 + dp(j))
            memo[i] = res
            return res
        
        ans = 0
        for i in range(n):
            ans = max(ans, dp(i))
        return ans

"""
Approach & Reasoning:
Define dp[i] = maximum number of indices visitable starting from index i.

For each position i we try all possible valid jumps to the left and to the right:
- Scan at most d positions in each direction.
- Stop scanning immediately when we encounter an element >= arr[i] because we cannot jump over or onto it.

Use memoization to avoid recomputing dp values. Since the graph is a DAG (jumps always go to strictly smaller values), there are no cycles.

Total time is O(n * d) because each dp call performs O(d) work and there are n states.

Space O(n) for memo array.

This correctly computes the longest reachable path under the given constraints.
"""
