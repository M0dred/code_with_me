from typing import List

class Solution:
    def totalWaviness(self, num1: int, num2: int) -> int:
        def count_waviness_up_to(N: int) -> int:
            if N < 0:
                return 0
            digits = [int(c) for c in str(N)]
            L = len(digits)
            memo = {}
            
            def dp(pos: int, tight: int, started: int, pprev: int, prev: int):
                key = (pos, tight, started, pprev, prev)
                if key in memo:
                    return memo[key]
                
                if pos == L:
                    return (1, 0)  # completed one number
                
                res_cnt = 0
                res_sum = 0
                up = digits[pos] if tight else 9
                
                for d in range(up + 1):
                    new_tight = 1 if tight and d == up else 0
                    
                    if started == 0 and d == 0:
                        new_started = 0
                        new_pprev = -1
                        new_prev = -1
                        contrib = 0
                    else:
                        new_started = 1
                        if started == 0:
                            # start now
                            new_pprev = -1
                            new_prev = d
                            contrib = 0
                        else:
                            if pprev == -1:
                                # second digit
                                new_pprev = prev
                                new_prev = d
                                contrib = 0
                            else:
                                # check prev for peak/valley
                                is_peak = (prev > pprev and prev > d)
                                is_valley = (prev < pprev and prev < d)
                                contrib = 1 if (is_peak or is_valley) else 0
                                new_pprev = prev
                                new_prev = d
                    
                    sub = dp(pos + 1, new_tight, new_started, new_pprev, new_prev)
                    sub_cnt, sub_sum = sub
                    res_cnt += sub_cnt
                    res_sum += sub_sum + contrib * sub_cnt
                
                memo[key] = (res_cnt, res_sum)
                return memo[key]
            
            _, total = dp(0, 1, 0, -1, -1)
            return total
        
        return count_waviness_up_to(num2) - count_waviness_up_to(num1 - 1)

"""
Approach & Reasoning:
Since num2 - num1 can be up to 10^15, we cannot iterate over each number. We use digit DP to compute the total waviness from 0 to N efficiently.

We define a recursive function with memoization that builds the number digit by digit from the left (MSB).

State:
- pos: current digit position
- tight: whether we are still bound by the digit limit of N
- started: whether we have placed a non-zero digit (to handle leading zeros correctly for the actual decimal representation)
- pprev, prev: the previous two digits (using -1 for "not yet placed")

When placing a digit d at the current position, we calculate if it creates a peak or valley at the previous position (if we have at least three digits so far). We add the contribution (0 or 1) multiplied by the number of ways to complete the suffix.

The DP returns a tuple (count of valid numbers, total waviness sum).

We compute f(num2) - f(num1-1), where f(N) is the total waviness for numbers from 0 to N.

This correctly handles all edge cases including numbers with different lengths and leading zeros.

Time Complexity: O(D * states) where D ≈ 16 (digits in 10^15) and states ≈ 16*2*2*11*11 ≈ 8k, very fast in practice.
Space Complexity: O(states) for memoization.
"""
