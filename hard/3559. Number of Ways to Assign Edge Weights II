from typing import List
from collections import deque

class Solution:
    def assignEdgeWeights(self, edges: List[List[int]], queries: List[List[int]]) -> List[int]:
        MOD = 10**9 + 7
        n = len(edges) + 1
        
        # Build adjacency list for the tree
        adj = [[] for _ in range(n + 1)]
        for u, v in edges:
            adj[u].append(v)
            adj[v].append(u)
        
        # Precompute depth and binary lifting table for LCA
        LOG = (n + 1).bit_length()
        parent = [[0] * (n + 1) for _ in range(LOG)]
        depth = [0] * (n + 1)
        
        # BFS from root node 1 to set depths and immediate parents
        queue = deque([1])
        visited = [False] * (n + 1)
        visited[1] = True
        
        while queue:
            u = queue.popleft()
            for v in adj[u]:
                if not visited[v]:
                    visited[v] = True
                    depth[v] = depth[u] + 1
                    parent[0][v] = u
                    queue.append(v)
        
        # Binary lifting table
        for k in range(1, LOG):
            for v in range(1, n + 1):
                parent[k][v] = parent[k - 1][parent[k - 1][v]]
        
        def lca(u: int, v: int) -> int:
            # Ensure u is the deeper node
            if depth[u] < depth[v]:
                u, v = v, u
            # Lift u up to the depth of v
            for k in range(LOG - 1, -1, -1):
                if depth[u] - (1 << k) >= depth[v]:
                    u = parent[k][u]
            if u == v:
                return u
            # Lift both u and v together
            for k in range(LOG - 1, -1, -1):
                if parent[k][u] != parent[k][v]:
                    u = parent[k][u]
                    v = parent[k][v]
            return parent[0][u]
        
        ans = []
        for u, v in queries:
            w = lca(u, v)
            # Number of edges on the path from u to v
            d = depth[u] + depth[v] - 2 * depth[w]
            # d == 0 means u == v, cost is 0 (even), so 0 valid assignments
            # For d >= 1, exactly half of the 2^d assignments give an odd sum
            if d == 0:
                ans.append(0)
            else:
                ans.append(pow(2, d - 1, MOD))
        
        return ans

'''
Approach:
1. For a path containing d edges, each edge can be assigned weight 1 (odd) or 2 (even). 
   The path cost is odd iff an odd number of edges are assigned 1. The count of such 
   assignments is C(d,1) + C(d,3) + ... = 2^(d-1) for d >= 1, and 0 for d = 0.
2. The problem reduces to finding the number of edges d on the path between ui and vi 
   for each query.
3. Build the tree adjacency list and run BFS from node 1 to compute depths and 
   immediate parents.
4. Build a binary lifting table to answer LCA queries in O(log n).
5. For each query, compute d = depth[u] + depth[v] - 2 * depth[lca(u,v)]. 
   Append 0 if d == 0, otherwise append 2^(d-1) mod (10^9 + 7).

Time Complexity: O((N + Q) log N), where N is the number of nodes and Q is the number of queries.
Space Complexity: O(N log N).
'''
